# Whop API Key (Required)
# Generate this in your Whop Developer Dashboard under API Keys.
# Use a "Company API Key" with least-privilege permissions.
WHOP_API_KEY=your_company_api_key_here

# Required for some scripts
WHOP_COMPANY_ID=your_company_id_here
WHOP_PRODUCT_ID=your_product_id_here
WHOP_APP_ID=your_app_id_here
WHOP_EXPERIENCE_ID=your_experience_id_here
